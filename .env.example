# Supabaseランキングを使う場合のみ設定（未設定ならlocalStorageに保存）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI TTSでお手本ボイスを生成する場合に設定（サーバー側のみ／NEXT_PUBLIC_は付けない）
# 未設定ならブラウザの読み上げ(Web Speech API)に自動フォールバックします
OPENAI_API_KEY=your_openai_api_key

# 任意: TTSモデルを変更したい場合（既定は gpt-4o-mini-tts。例: tts-1 / tts-1-hd）
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
